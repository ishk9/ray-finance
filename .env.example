# Anthropic API key for AI chat — https://console.anthropic.com
ANTHROPIC_API_KEY=

# ── US Banks (Plaid) ──────────────────────────────────────────────────────────
# Plaid credentials for bank sync — https://dashboard.plaid.com
PLAID_CLIENT_ID=
PLAID_SECRET=
PLAID_ENV=production

# Separate key for encrypting stored Plaid access tokens (any strong passphrase)
PLAID_TOKEN_SECRET=

# ── Indian Banks (Setu Account Aggregator) ───────────────────────────────────
# Setu credentials — https://console.setu.co
SETU_CLIENT_ID=
SETU_CLIENT_SECRET=
SETU_PRODUCT_INSTANCE_ID=
# sandbox | production
SETU_ENV=sandbox

# Optional: ngrok auth token for real-time session webhooks — https://dashboard.ngrok.com
# Without this, Ray polls the Setu API every few seconds instead.
NGROK_AUTH_TOKEN=

# ── Database ──────────────────────────────────────────────────────────────────
# Database encryption key (any strong passphrase)
DB_ENCRYPTION_KEY=
